# Site
# Your real production domain. Canonical URLs, sitemap and Open Graph tags all derive from this.
NEXT_PUBLIC_SITE_URL=https://www.24x7appliancerepairs.com

# Lead email (nodemailer SMTP)
# Without these, leads are only logged to the server console — no email is sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
LEAD_FROM_EMAIL=
LEAD_TO_EMAIL=

# AI Repair Assistant (Anthropic Claude API)
# Without ANTHROPIC_API_KEY, the assistant shows "temporarily unavailable" and degrades gracefully.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Analytics — each is independently optional; unset ones simply don't render.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=
